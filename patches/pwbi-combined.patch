+    $this->assertArrayNotHasKey('token_refresh_minutes', $settings);
+    // No session-specific data (e.g. CSRF tokens) in drupalSettings — the
+    // route is a plain GET endpoint so the render cache is session-agnostic.
+    $this->assertArrayNotHasKey('token_refresh_csrf', $settings);
+  }
+
+  /**
+   * Cache max-age equals the full token lifetime when token refresh is on.
+   *
+   * The JS handles in-place token refresh via setAccessToken(), so the render
+   * cache does not need to be artificially shortened — it should live for the
+   * full duration of the token regardless of whether refresh is enabled.
+   *
+   * @covers ::viewElements
+   */
+  public function testCacheMaxAgeEqualsFullTokenLifetimeWhenRefreshEnabled(): void {
+    \Drupal::configFactory()
+      ->getEditable('pwbi.settings')
+      ->set('token_refresh_enabled', TRUE)
+      ->save();
+
+    ['display' => $display, 'media' => $media] = $this->createFixture(1200);
+    $build = $display->build($media);
+    $renderer = \Drupal::service('renderer');
+    $renderer->renderInIsolation($build['embed']);
+
+    $this->assertSame(1200, $build['embed']['#cache']['max-age']);
   }
 
