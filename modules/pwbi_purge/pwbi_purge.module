<?php

/**
 * @file
 * PowerBi Purge module.
 */

declare(strict_types=1);

use Drupal\Core\Hook\Attribute\LegacyHook;
use Drupal\pwbi_purge\Hook\PurgeHooks;

/**
 * Implements hook_cron().
 *
 * @phpstan-ignore-next-line
 */
#[LegacyHook]
function pwbi_purge_cron() {
  // Call the Drupal 11 hook.
  \Drupal::service(PurgeHooks::class)->purgeOnCron();
}
